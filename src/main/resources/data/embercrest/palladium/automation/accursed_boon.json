{
  "trigger": {
    "trigger": "palladium:ability_enabled",
    "conditions": {
      "ability": "embercrest:lord_contender#accursed_boon_bar"
    }
  },
  "action": {
    "type": "palladium:conditional",
    "condition": [{
      "type": "palladium:number_data_attachment",
      "attachment": "embercrest:accursed_boon_enabled",
      "min": 1,
      "max": 1
    }],
    "on_true": {
      "type": "palladium:run_command",
      "command": "palladium data-attachment set entity @s embercrest:accursed_boon_enabled 0"
    },
    "on_false": {
      "type": "palladium:run_command",
      "command": "palladium data-attachment set entity @s embercrest:accursed_boon_enabled 1"
    }}
}